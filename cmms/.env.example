# Base de datos
POSTGRES_PASSWORD=cmms_secure_pass_2024

# JWT
JWT_SECRET=cmms_super_secret_jwt_key_change_in_production_2024
JWT_EXPIRES_IN=24h

# MQTT (EMQX)
EMQX_DASHBOARD_PASSWORD=admin123
MQTT_USERNAME=
MQTT_PASSWORD=

# MinIO
MINIO_ROOT_USER=cmmsadmin
MINIO_ROOT_PASSWORD=cmms_minio_pass_2024

# Email (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# WhatsApp Business API
WHATSAPP_TOKEN=your_whatsapp_business_token
WHATSAPP_PHONE_ID=your_phone_number_id

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# IA Service
AI_DEVICE=cpu

# Dominio publico para Caddy
# Debe coincidir exactamente con el registro DNS publico.
CMMS_DOMAIN=cmms.controlmc.click

# Modo proxy:
# - public: Caddy emite HTTPS directo por puertos 80/443.
# - tunnel: Cloudflare emite HTTPS y Caddy escucha solo HTTP interno.
CADDY_SITE_ADDRESS=cmms.controlmc.click

# Cloudflare Tunnel opcional. Usar si 80/443 no estan abiertos.
CLOUDFLARED_TOKEN=

# Frontend
VITE_API_URL=/api
VITE_WS_URL=/
VITE_MQTT_WS_URL=/mqtt
